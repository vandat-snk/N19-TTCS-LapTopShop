<% layout('base') -%>

<div class="container-fluid py-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">

    <h3 class="fw-bold d-flex align-items-center gap-2" style="color:#d4a017;">
      <i class="fa-solid fa-star"></i>
      Quản lý đánh giá
    </h3>

  </div>

  <!-- Card -->
  <div class="card shadow-sm border-0"
       style="border-radius:14px; overflow:hidden; background:#fffdf5;">

    <div class="card-header border-0 py-3"
         style="background:#fff6dd;">

      <h5 class="mb-0 fw-semibold d-flex align-items-center gap-2" style="color:#b8860b;"><i class="fa-solid fa-list"></i>
        Danh sách đánh giá
      </h5>

    </div>

    <div class="card-body">

      <div class="table-responsive">

        <table class="table table-hover align-middle" id="sample_data">

          <thead style="background:#fff1c2;">
            <tr style="color:#8a6d1e;">
              <th><i class="fa-solid fa-user"></i> User Name</th>
              <th><i class="fa-solid fa-box"></i> Product Name</th>
              <th><i class="fa-solid fa-comment"></i> Review</th>
              <th><i class="fa-solid fa-star"></i> Rating</th>
              <th><i class="fa-solid fa-gear"></i> Action</th>
            </tr>
          </thead>

          <tbody></tbody>

        </table>

      </div>

    </div>

  </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="action_modal">
  <div class="modal-dialog">
    <div class="modal-content"
         style="border-radius:14px; overflow:hidden; background:#fffdf5;">

      <form method="post" id="sample_form" enctype="multipart/form-data">

        <!-- Header -->
        <div class="modal-header"
             style="background:#fff1c2;">

          <h5 class="modal-title fw-bold" id="dynamic_modal_title"
              style="color:#b8860b;">
            Đánh giá
          </h5>

          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <!-- Body -->
        <div class="modal-body">

          <div class="mb-2">
            <label class="form-label">Rating</label>
            <select name="rating" class="form-control" id="rating">
              <option value="1">1</option>
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4">4</option>
              <option value="5">5</option>
            </select>
          </div>

          <div class="mb-2">
            <label class="form-label">Nội dung đánh giá</label>
            <input type="text" name="review" id="review" class="form-control" />
          </div>

        </div>

        <!-- Footer -->
        <div class="modal-footer">

          <input type="hidden" name="id" id="id" />
          <input type="hidden" name="action" id="action" value="Add" />

          <button type="button"
                  class="btn btn-secondary"
                  data-bs-dismiss="modal">
            Đóng
          </button>

          <button type="submit"
                  id="action_button"
                  class="btn"
                  style="background:#d4a017; color:white;">
            Lưu
          </button>

        </div>

      </form>

    </div>
  </div>
</div>

<!-- STYLE -->
<style>

  #sample_data tbody tr:hover {
    background: #fff6dd;
    transition: 0.2s;
  }

  .form-control:focus {
    border-color: #d4a017;
    box-shadow: 0 0 0 0.15rem rgba(212,160,23,0.25);
  }

</style>

<script src="/js/review.js"></script>