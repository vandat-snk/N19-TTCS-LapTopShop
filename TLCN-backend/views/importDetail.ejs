<% layout('base') -%>

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h3 class="fw-bold" style="color:#d63384;">
            📄 Chi tiết phiếu nhập
        </h3>

        <a href="/imports" class="btn btn-sm"
           style="background:#ff4da6; color:white; border-radius:10px;">
            ← Quay lại
        </a>

    </div>

    <!-- Card -->
    <div class="card shadow-sm border-0" style="border-radius:14px; overflow:hidden;">

        <!-- Header -->
        <div class="card-header bg-white py-4 border-0">

            <h5 class="mb-0">
                <span style="color:#a8729a; font-size:18px;">
                    👤 Người nhập: <%= data.user.name %>
                </span>
            </h5>

        </div>

        <!-- Body -->
        <div class="card-body p-4">

            <% data.invoice.forEach(function(value){ 
                const name = value.title.length > 28
                    ? value.title.slice(0, 29) + "..."
                    : value.title;
            %>

            <div class="card mb-3 border-0 shadow-sm"
                 style="border-radius:12px;">

                <div class="card-body">

                    <div class="row align-items-center">

                        <!-- Image -->
                        <div class="col-md-2 text-center">
                            <img src="<%= value.image %>"
                                 class="img-fluid rounded"
                                 style="max-height:80px;">
                        </div>

                        <!-- Name -->
                        <div class="col-md-4 text-center text-md-start">
                            <p class="mb-0 fw-semibold">
                                <%= name %>
                            </p>
                        </div>

                        <!-- Quantity -->
                        <div class="col-md-3 text-center">
                            <span class="badge"
                                  style="background:#fff0f6; color:#d63384; padding:8px 12px;">
                                Số lượng: <%= value.quantity %>
                            </span>
                        </div>

                        <!-- Price -->
                        <div class="col-md-3 text-center">
                            <span class="fw-bold" style="color:#198754;">
                                <%= value.price %> VND
                            </span>
                        </div>

                    </div>

                </div>
            </div>

            <% }); %>

            <!-- Invoice info -->
            <hr>

            <div class="d-flex justify-content-between flex-wrap">

                <p class="mb-1 text-muted">
                    🧾 Mã phiếu: <strong><%= data._id %></strong>
                </p>

                <p class="mb-1 text-muted">
                    📅 Ngày tạo: <strong><%= data.date %></strong>
                </p>

                <p class="mb-1 fw-bold" style="color:#198754;">
                    Tổng tiền: <%= data.totalPrice %> VND
                </p>

            </div>

        </div>

        <!-- Footer -->
        <div class="card-footer text-end py-4"
             style="background:#ff4da6;">

            <h5 class="text-white mb-0">
                💰 Tổng thanh toán:
                <span class="fw-bold ms-2">
                    <%= data.totalPrice %> VND
                </span>
            </h5>

        </div>

    </div>
</div>

<!-- UI style nhẹ -->
<style>

    .card:hover {
        transform: translateY(-2px);
        transition: 0.2s;
    }

</style>