<% layout('base') -%>

<div class="container-fluid py-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">

    <h3 class="fw-bold d-flex align-items-center gap-2" style="color:#0d6efd;"><i class="fa-solid fa-users"></i>
      Quản lý người dùng
    </h3>

  </div>

  <!-- Card -->
  <div class="card shadow-sm border-0" style="border-radius:14px; overflow:hidden;">

    <div class="card-header bg-white border-0 py-3">

      <h5 class="mb-0 fw-semibold d-flex align-items-center gap-2" style="color:#0d6efd;"><i class="fa-solid fa-list"></i>
        Danh sách người dùng
      </h5>

    </div>

    <div class="card-body">

      <div class="table-responsive">

        <table class="table table-hover align-middle" id="sample_data">

          <thead style="background:#e7f1ff;">
            <tr style="color:#0d6efd;">
              <th><i class="fa-solid fa-image"></i> Avatar</th>
              <th><i class="fa-solid fa-user"></i> Họ tên</th>
              <th><i class="fa-solid fa-envelope"></i> Email</th>
              <th><i class="fa-solid fa-circle-check"></i> Trạng thái</th>
              <th><i class="fa-solid fa-gear"></i> Thao tác</th>
            </tr>
          </thead>

          <tbody></tbody>

        </table>

      </div>

    </div>

  </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="action_modal">
  <div class="modal-dialog">
    <div class="modal-content" style="border-radius:14px; overflow:hidden;">

      <form method="post" id="sample_form" enctype="multipart/form-data">

        <!-- Header -->
        <div class="modal-header" style="background:#e7f1ff;">
          <h5 class="modal-title fw-bold text-primary" id="dynamic_modal_title">
            Thêm người dùng
          </h5>

          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <!-- Body -->
        <div class="modal-body">

          <div class="mb-2">
            <label class="form-label">Họ tên</label>
            <input type="text" id="name" class="form-control" />
          </div>

          <div class="mb-2">
            <label class="form-label">Email</label>
            <input type="text" id="email" class="form-control" />
          </div>

          <div class="mb-2">
            <label class="form-label">Mật khẩu</label>
            <input type="password" id="password" class="form-control" />
          </div>

          <div class="mb-2">
            <label class="form-label">Xác nhận mật khẩu</label>
            <input type="password" id="passwordConfirm" class="form-control" />
          </div>

        </div>

        <!-- Footer -->
        <div class="modal-footer">

          <input type="hidden" id="id" />
          <input type="hidden" id="action" value="Add" />

          <button type="button"
                  class="btn btn-secondary"
                  data-bs-dismiss="modal">
            Đóng
          </button>

          <button type="submit"
                  id="action_button"
                  class="btn btn-primary">
            Thêm
          </button>

        </div>

      </form>

    </div>
  </div>
</div>

<!-- STYLE -->
<style>

  #sample_data tbody tr:hover {
    background: #e7f1ff;
    transition: 0.2s;
  }

  .avatar-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #0d6efd;
  }

</style>

<script src="/js/user.js"></script>