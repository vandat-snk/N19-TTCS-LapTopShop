<% layout('base') -%>

<div class="container-fluid py-3">

    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">

<h2 class="fw-bold d-flex align-items-center gap-2" style="color:#ff4da6;">
    <i class="fa-solid fa-file-import"></i>
    Quản lý phiếu nhập
</h2>

        <button type="button"
            id="add_data"
            class="btn btn-sm"
            style="background:#ff4da6; color:white; border-radius:10px;">
            + Thêm phiếu nhập
        </button>

    </div>

    <!-- Card -->
    <div class="card shadow-sm border-0" style="border-radius:14px;">

        <div class="card-header bg-white border-0 py-3">
            <h5 class="mb-0 fw-bold" style="color:#d63384;">
                Danh sách phiếu nhập
            </h5>
        </div>

        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle" id="sample_data">

                    <thead style="background:#fff0f6;">
                        <tr>
                            <th>Người nhập</th>
                            <th>Sản phẩm</th>
                            <th>Tổng tiền</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>

                    <tbody></tbody>

                </table>
            </div>

        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="action_modal">
    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content" style="border-radius:14px; overflow:hidden;">

            <form method="post" id="sample_form" enctype="multipart/form-data">

                <!-- Header -->
                <div class="modal-header" style="background:#fff0f6;">
<button type="button"
    id="add_data"
    class="btn btn-sm"
    style="background:#ff4da6; color:white; border-radius:10px;">
    
    <i class="fa-solid fa-plus"></i> Thêm phiếu nhập
</button>

                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Sản phẩm</label>

                        <select id="invoice_items"
                                name="invoices[]"
                                multiple="multiple"
                                class="form-control">
                        </select>
                    </div>

                    <div class="list-item"></div>

                </div>

                <!-- Footer -->
                <div class="modal-footer">

                    <input type="hidden" name="id" id="id" />
                    <input type="hidden" name="action" id="action" value="Add" />

                    <button type="button"
                        class="btn btn-light"
                        data-bs-dismiss="modal">
                        Đóng
                    </button>

                    <button type="submit"
                        id="action_button"
                        class="btn"
                        style="background:#ff4da6; color:white;">
                        Thêm
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

<!-- JS giữ nguyên -->
<script src="/js/import.js"></script>

<!-- UI nhẹ (không ảnh hưởng JS) -->
<style>

    #sample_data thead th {
        color: #d63384;
        font-weight: 600;
    }

    .card {
        border-radius: 14px !important;
    }

    .table-hover tbody tr:hover {
        background: #fff0f6;
    }

    .modal-content {
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

</style>