<% layout('base') -%>

<div class="container-fluid py-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">

      <h3 class="fw-bold d-flex align-items-center gap-2" style="color:#198754;"><i class="fa-solid fa-box"></i>
        Quản lý đơn hàng
      </h3>

  </div>

  <!-- Card -->
  <div class="card shadow-sm border-0" style="border-radius:14px; overflow:hidden;">

    <div class="card-header bg-white border-0 py-3">

      <h5 class="mb-0 fw-semibold d-flex align-items-center gap-2" style="color:#198754;">
        <i class="fa-solid fa-list"></i>
        Danh sách đơn hàng
      </h5>

    </div>

    <div class="card-body">

      <div class="table-responsive">

        <table class="table table-hover align-middle" id="sample_data">

          <thead style="background:#eaf7ef;">
            <tr style="color:#198754;">
              <th><i class="fa-solid fa-user"></i> Người mua</th>
              <th><i class="fa-solid fa-cart-shopping"></i> Giỏ hàng</th>
              <th><i class="fa-solid fa-calendar-days"></i> Ngày tạo</th>
              <th><i class="fa-solid fa-circle-info"></i> Trạng thái</th>
              <th><i class="fa-solid fa-money-bill-wave"></i> Tổng tiền</th>
              <th><i class="fa-solid fa-gear"></i> Thao tác</th>
            </tr>
          </thead>

          <tbody></tbody>

        </table>

      </div>

    </div>

  </div>
</div>

<!-- STYLE -->
<style>

  #sample_data tbody tr:hover {
    background: #eaf7ef;
    transition: 0.2s;
  }

  .order-badge {
    padding: 6px 10px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 600;
  }

  .badge-success { 
    background:#d1e7dd; 
    color:#198754; 
  }

  .badge-warning { 
    background:#fff3cd; 
    color:#7a5d00; 
  }

  .badge-danger  { 
    background:#f8d7da; 
    color:#842029; 
  }

  .badge-info    { 
    background:#d1f7e2; 
    color:#0f5132; 
  }

  /* button xanh lá đồng bộ */
  .btn-primary {
    background:#198754 !important;
    border-color:#198754 !important;
  }

  .btn-primary:hover {
    background:#157347 !important;
    border-color:#157347 !important;
  }

</style>

<script src="/js/order.js"></script>