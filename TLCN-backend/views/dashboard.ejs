<% layout('base') -%>

<div class="container-fluid py-3">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">

        <h2 class="fw-bold m-0" style="color:#d63384;">
            Bảng điều khiển
        </h2>

    </div>

    <!-- Cards -->
    <div class="row g-3 mb-4">

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body">
                    <div class="text-muted">Nhập hàng</div>
                    <h5 id="totalInvoice" class="fw-bold text-danger"></h5>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body">
                    <div class="text-muted">Doanh thu</div>
                    <h5 id="totalRevenue" class="fw-bold text-success"></h5>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body">
                    <div class="text-muted">Người dùng</div>
                    <h5 id="totalUser" class="fw-bold text-primary"></h5>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body">
                    <div class="text-muted">Đơn hàng</div>
                    <h5 id="totalOrder" class="fw-bold text-warning"></h5>
                </div>
            </div>
        </div>

    </div>

    <!-- Charts -->
    <div class="row g-3">

        <!-- Line / Area chart -->
        <div class="col-xl-8 col-lg-7">

            <div class="card border-0 shadow-sm rounded-3">

                <div class="card-header bg-white border-0">
                    <h6 class="fw-bold m-0" style="color:#ff4da6;">
                        Tổng quan thống kê
                    </h6>
                </div>

                <div class="card-body">
                    <canvas id="myAreaChart"></canvas>
                </div>

            </div>

        </div>

        <!-- Pie chart -->
        <div class="col-xl-4 col-lg-5">

            <div class="card border-0 shadow-sm rounded-3">

                <div class="card-header bg-white border-0">
                    <h6 class="fw-bold m-0" style="color:#ff4da6;">
                        Nguồn đơn hàng
                    </h6>
                </div>

                <div class="card-body">

                    <div class="chart-pie pt-3 pb-2">
                        <canvas id="myPieChart"></canvas>
                    </div>

                    <div class="mt-3 small text-center">

                        <span class="d-inline-block me-2">
                            <i class="fas fa-circle" style="color: red;"></i> Huỷ
                        </span>

                        <span class="d-inline-block me-2">
                            <i class="fas fa-circle" style="color: orange;"></i> Đang xử lý
                        </span>

                        <span class="d-inline-block me-2">
                            <i class="fas fa-circle" style="color: gray;"></i> Chờ hàng
                        </span>

                        <span class="d-inline-block me-2">
                            <i class="fas fa-circle" style="color: blue;"></i> Giao hàng
                        </span>

                        <span class="d-inline-block">
                            <i class="fas fa-circle" style="color: green;"></i> Thành công
                        </span>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- Chart JS giữ nguyên -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js"></script>
<script src="js/dashboard.js"></script>