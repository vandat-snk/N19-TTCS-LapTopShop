<% layout('base') -%>

<div class="container-fluid py-4">

  <div class="row g-4">

    <!-- LEFT: ORDER INFO -->
    <div class="col-lg-8">

      <div class="card shadow-sm border-0" style="border-radius:14px; overflow:hidden;">

        <!-- HEADER -->
        <div class="card-header bg-white py-4 border-0">

          <h5 class="mb-0 fw-bold d-flex align-items-center gap-2" style="color:#d63384;"><i class="fa-solid fa-receipt"></i>
            Đơn hàng #<%= data._id %>
          </h5>

          <small class="text-muted d-flex align-items-center gap-1"><i class="fa-solid fa-user"></i>
            Khách hàng: <strong><%= data.user ? data.user.name : 'N/A' %></strong>
          </small>

        </div>

        <!-- PRODUCTS -->
        <div class="card-body">

          <% data.cart.forEach(function(value){
            const name = value.title && value.title.length > 28
              ? value.title.slice(0, 29)
              : (value.title || 'Sản phẩm');
          %>

          <div class="card mb-3 border-0 shadow-sm" style="border-radius:12px;">

            <div class="card-body">

              <div class="row align-items-center">

                <div class="col-md-2 text-center">
                  <img src="<%= value.image || '' %>"
                       style="width:70px; height:70px; object-fit:cover; border-radius:10px;"
                       onerror="this.style.display='none'">
                </div>

                <div class="col-md-5">
                  <div class="fw-semibold"><%= name %></div>
                </div>

                <div class="col-md-2 text-center">
                  SL: <%= value.quantity %>
                </div>

                <div class="col-md-3 text-end">
                  <div class="fw-bold text-danger">
                    <%= value.price ? value.price.toLocaleString('vi-VN') : 0 %> VND
                  </div>
                </div>

              </div>

            </div>

          </div>

          <% }) %>

          <!-- INFO -->
          <div class="mt-4">

            <div class="d-flex justify-content-between">
              <span class="text-muted"><i class="fa-solid fa-calendar-days"></i> Ngày đặt:</span>
              <strong><%= data.date %></strong>
            </div>

            <div class="d-flex justify-content-between">
              <span class="text-muted"><i class="fa-solid fa-tag"></i> Giảm giá:</span>
              <strong><%= data.discount ? data.discount.toLocaleString('vi-VN') : 0 %> VND</strong>
            </div>

            <div class="d-flex justify-content-between">
              <span class="text-muted"><i class="fa-solid fa-credit-card"></i> Thanh toán:</span>
              <strong><%= data.paymentInfo && data.paymentInfo.method ? data.paymentInfo.method : "" %></strong>
            </div>

            <% if (data.shippingDetails) { %>
            <hr>
            <div class="d-flex justify-content-between">
              <span class="text-muted"><i class="fa-solid fa-user"></i> Người nhận:</span>
              <strong><%= data.shippingDetails.receiver %></strong>
            </div>
            <div class="d-flex justify-content-between">
              <span class="text-muted"><i class="fa-solid fa-phone"></i> SĐT:</span>
              <strong><%= data.shippingDetails.phone %></strong>
            </div>
            <div class="d-flex justify-content-between">
              <span class="text-muted"><i class="fa-solid fa-location-dot"></i> Địa chỉ:</span>
              <strong><%= data.shippingDetails.address %></strong>
            </div>
            <% } %>

          </div>

        </div>

        <!-- FOOTER TOTAL -->
        <div class="card-footer text-end"
             style="background:#fff0f6; border:0;">

          <h5 class="mb-0 d-flex justify-content-end align-items-center gap-2" style="color:#d63384;"><i class="fa-solid fa-coins"></i>
            Tổng tiền: <%= data.totalPrice ? data.totalPrice.toLocaleString('vi-VN') : 0 %> VND
          </h5>

        </div>

      </div>

    </div>

    <!-- RIGHT: ACTION -->
    <div class="col-lg-4">

      <div class="card shadow-sm border-0 text-center p-4" style="border-radius:14px;">

        <h5 style="color:#d63384;">⚙️ Trạng thái đơn hàng</h5>

        <input type="hidden" value="<%= data.status %>" id="status" />

        <!-- STATUS FLOW -->
        <div class="progress my-3">
          <div id="progress-bar" class="progress-bar" style="width:0%"></div>
        </div>

        <!-- ACTION BUTTONS -->
        <div class="mt-4">

          <% if (data.status=="Cancelled") { %>

            <button class="btn btn-danger w-100" disabled>Đã huỷ</button>

          <% } else if(data.status=="Processed") { %>

            <button class="btn btn-outline-danger w-100 mb-2"
                    data-id="<%=data._id%>"
                    onclick="cancelOrder(this)">
              Huỷ đơn
            </button>

            <button class="btn btn-success w-100"
                    value="Waiting Goods"
                    data-id="<%=data._id%>"
                    onclick="acceptOrder(this)">
              Xác nhận
            </button>

          <% } else if(data.status=="Waiting Goods") { %>

            <button class="btn btn-outline-danger w-100 mb-2"
                    onclick="cancelOrder(this)"
                    data-id="<%=data._id%>">
              Huỷ đơn
            </button>

            <button class="btn btn-primary w-100"
                    value="Delivery"
                    data-id="<%=data._id%>"
                    onclick="acceptOrder(this)">
              Đang giao
            </button>

          <% } else if(data.status=="Delivery") { %>

            <button class="btn btn-outline-danger w-100 mb-2"
                    onclick="cancelOrder(this)"
                    data-id="<%=data._id%>">
              Huỷ đơn
            </button>

            <button class="btn btn-success w-100"
                    value="Success"
                    data-id="<%=data._id%>"
                    onclick="acceptOrder(this)">
              Hoàn tất
            </button>

          <% } else { %>

            <button class="btn btn-success w-100" disabled>
              Đã thanh toán
            </button>

          <% } %>

        </div>

        <!-- BACK -->
        <a href="/orders" class="btn btn-light mt-4 w-100">
          ← Quay lại
        </a>

      </div>

    </div>

  </div>
</div>

<!-- STYLE -->
<style>

  .card {
    border-radius: 14px !important;
  }

  .progress-bar {
    background: #ff4da6;
  }

</style>

<script src="/js/detail.js"></script>
