<% layout('base') -%>

<div class="container-fluid py-3">

    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">

        <h2 class="fw-bold m-0" style="color:#d63384;">
            <%= title %>
        </h2>

        <div class="d-flex gap-2 flex-wrap">

            <input class="form-control shadow-sm"
                id="dateRange"
                placeholder="Chọn khoảng thời gian"
                style="min-width:220px; border-radius:10px;">

            <div class="dropdown">
                <button class="btn dropdown-toggle shadow-sm"
                    style="background:linear-gradient(45deg,#ff4da6,#ff80bf);
                           color:white; border:none; border-radius:10px;"
                    type="button"
                    data-bs-toggle="dropdown">

                    Bộ lọc
                </button>

                <ul class="dropdown-menu shadow-sm p-2">

                    <li class="mb-1">
                        <input class="form-control" type="date" id="birthday">
                    </li>

                    <li><button id="inWeek" onclick="changeData(this)" class="btn btn-light w-100">Tuần này</button></li>
                    <li><button id="inMonth" onclick="changeData(this)" class="btn btn-light w-100">Tháng này</button></li>
                    <li><button id="inYear" onclick="changeData(this)" class="btn btn-light w-100">Năm này</button></li>
                    <li><button id="allYear" onclick="changeData(this)" class="btn btn-light w-100">Tất cả</button></li>

                </ul>
            </div>

        </div>
    </div>

    <!-- Cards -->
    <div class="row g-3 mb-4">

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body">
                    <div class="text-muted">Nhập hàng</div>
                    <h5 id="totalInvoice" class="fw-bold text-danger"></h5>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body">
                    <div class="text-muted">Doanh thu</div>
                    <h5 id="totalRevenue" class="fw-bold text-success"></h5>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body">
                    <div class="text-muted">Người dùng</div>
                    <h5 id="totalUser" class="fw-bold text-primary"></h5>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body">
                    <div class="text-muted">Đơn hàng</div>
                    <h5 id="totalOrder" class="fw-bold text-warning"></h5>
                </div>
            </div>
        </div>

    </div>

    <!-- Content -->
    <div class="row g-3">

        <!-- Products -->
        <div class="col-xl-8">

            <div class="card border-0 shadow-sm rounded-3">

                <div class="card-header bg-white border-0">
                    <ul class="nav nav-pills gap-2">

                        <li class="nav-item">
                            <button class="nav-link active"
                                style="background:#ff4da6; color:white;">
                                Sản phẩm bán chạy
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                style="color:#ff4da6;">
                                Sản phẩm tồn kho
                            </button>
                        </li>

                    </ul>
                </div>

                <div class="card-body">

                    <div id="sell-product" class="row g-2"></div>
                    <div id="inventory-product" class="row g-2"></div>

                </div>
            </div>
        </div>

        <!-- Pie chart -->
        <div class="col-xl-4">

            <div class="card border-0 shadow-sm rounded-3">

                <div class="card-header bg-white border-0">
                    <h6 class="fw-bold m-0" style="color:#ff4da6;">
                        Nguồn đơn hàng
                    </h6>
                </div>

                <div class="card-body">
                    <canvas id="myPieChart"></canvas>
                </div>

            </div>

        </div>

    </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js"></script>
<script src="js/analytic.js"></script>